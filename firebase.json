{
  "hosting": {
    "public": "lp",
    "cleanUrls": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/privacy-policy", "destination": "/privacy-policy.html" },
      { "source": "/terms", "destination": "/terms.html" },
      { "source": "/contact", "destination": "/contact.html" }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
